{
  "name": "betting-backend",
  "version": "1.0.0",
  "scripts": {
    "dev": "prisma migrate dev --skip-seed && tsx watch --env-file=.env src/server.ts",
    "dev:server": "tsx watch --env-file=.env src/server.ts",
    "db:migrate": "prisma migrate dev --skip-seed",
    "db:reset": "prisma migrate reset --force --skip-seed",
    "build": "tsup src/server.ts --format cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "5.14.0",
    "@types/node-cron": "^3.0.11",
    "express": "4.19.2",
    "node-cron": "^4.2.1",
    "zod": "3.23.8",
    "prisma": "5.14.0",
    "tsup": "8.1.0",
    "tsx": "4.15.7",
    "typescript": "5.5.2"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.14.2",
    "@typescript-eslint/eslint-plugin": "7.13.0",
    "@typescript-eslint/parser": "7.13.0",
    "eslint": "8.57.0",
    "prettier": "3.3.2",
    "ts-node": "10.9.2",
    "vitest": "1.6.0"
  },
  "engines": {
    "node": ">=20 <23"
  }
}
